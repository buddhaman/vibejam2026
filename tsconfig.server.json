{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "outDir": "dist/server",
    "rootDir": "server/src",
    "noEmit": false,
    "experimentalDecorators": true,
    "useDefineForClassFields": false
  },
  "include": ["server/src/**/*.ts"]
}
